# Required for the real Slack bot
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
OPENAI_API_KEY=sk-your-openai-key

# Required for production. Use managed Postgres on Render, Railway, Cloud SQL, Supabase, Neon, etc.
DATABASE_URL=postgresql://user:password@host:5432/slack_ai

# Optional. Used only when DATABASE_URL is not set, for smoke tests.
SQLITE_PATH=data/slack-ai.sqlite3

# OpenAI models
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Search behavior
# channel = answer from current channel only
# workspace = search every channel the bot has ingested in the same workspace
SEARCH_SCOPE=workspace
MAX_SEARCH_ROWS=5000
MAX_CONTEXT_MESSAGES=12
CONTEXT_NEIGHBOR_MESSAGES=2
MAX_CONTEXT_CHARS=26000
EMBED_ON_INGEST=true

# Optional safety rail. Comma-separated Slack channel IDs where the bot is allowed to answer.
# Useful if you want all cross-channel questions to happen inside a private #company-ai channel.
ALLOWED_ANSWER_CHANNEL_IDS=

# Optional. If set, the bot will avoid indexing its own Slack messages.
SLACK_OWN_BOT_ID=
